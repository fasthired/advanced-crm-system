# Supabase Configuration
# Get these values from your Supabase project:
# 1. Go to supabase.com and create a project
# 2. Go to Settings > API
# 3. Copy the Project URL and anon public key
# 4. Rename this file to .env.local and fill in your values

NEXT_PUBLIC_SUPABASE_URL=your_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key_here
ADMIN_SETUP_EMAIL=admin@example.com
ADMIN_SETUP_PASSWORD=change_this_password
ADMIN_SETUP_FULL_NAME=Admin User
ADMIN_SETUP_TOKEN=change_this_random_setup_token
